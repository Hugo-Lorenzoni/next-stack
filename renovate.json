{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone"
  ],
  "timezone": "UTC",
  "schedule": ["before 5am on monday"],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "description": "Group all React and Next.js core packages together",
      "matchPackagePatterns": ["^next", "^react", "^react-dom"],
      "groupName": "Next.js Core Packages"
    },
    {
      "description": "Group all @types packages",
      "matchPackagePatterns": ["^@types/"],
      "groupName": "Types Definitions",
      "automerge": true
    },
    {
      "description": "Automerge patch and minor updates for devDependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    }
  ],
  "platformAutomerge": true,
  "rangeStrategy": "bump"
}
